rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the logged-in user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Checks if the logged-in user has the admin role
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Rules for 'activities' collection
    match /activities/{activityId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'missions' collection
    match /missions/{missionId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Rules for 'reports' collection
    match /reports/{reportId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Rules for 'predictions' collection
    match /predictions/{predId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'ecoProfiles' collection
    match /ecoProfiles/{profileId} {
      allow read: if isAuthenticated(); // Allow users to view profiles for leaderboards
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'challenges' collection
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // Allow users to update participant lists by joining/completing challenges
      allow update: if isAuthenticated() && (
        request.resource.data.joinedBy.difference(resource.data.joinedBy).size() <= 1 ||
        request.resource.data.completedBy.difference(resource.data.completedBy).size() <= 1
      );
    }

    // Rules for 'leaderboards' collection
    match /leaderboards/{leaderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'carbonHistory' collection
    match /carbonHistory/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'futureSimulations' collection
    match /futureSimulations/{simId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'decisionAnalysis' collection
    match /decisionAnalysis/{decId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Rules for 'notifications' collection
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
